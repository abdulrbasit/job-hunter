# Copy this file to .env and fill in your values.
# These names are fixed by job-hunter code and GitHub workflow templates.
# .env is protected; job-hunter sync will never overwrite it.

# LLM providers (set at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional job board APIs (free keys)
ADZUNA_API_KEY=        # Adzuna
ADZUNA_APP_ID=         # Adzuna App ID
REED_API_KEY=          # Reed (UK)

# Point to this workspace (optional; CLI auto-detects from cwd)
# JOB_HUNTER_ROOT=/path/to/this/workspace
